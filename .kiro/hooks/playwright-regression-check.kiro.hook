{
  "enabled": true,
  "name": "Playwright Regression Check",
  "description": "Runs `npx playwright test` automatically when frontend HTML files or server TypeScript files are saved, ensuring no regressions are introduced.",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "public/**/*.html",
      "src/**/*.ts"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "npx playwright test"
  }
}